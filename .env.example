# IntelX (https://intelx.io/account?tab=developer)
INTELX_API_KEY=
INTELX_BASE_URL=https://free.intelx.io
INTELX_DELAY=1.0

# SMTP e-mail rapport
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_TO=
SMTP_TLS=true
SMTP_ATTACH=true

# Standaard lookback-venster in dagen (default 7)
CUTOFF_DAYS=7

# Optioneel: IPInfo token voor ASN lookups
IPINFO_TOKEN=

# Optioneel: pad naar externe tools
SUBFINDER_PATH=
AMASS_PATH=
NMAP_PATH=
